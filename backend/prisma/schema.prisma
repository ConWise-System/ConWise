generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum CompanyStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum UserRole {
  PLATFORM_ADMIN
  COMPANY_ADMIN
  PROJECT_MANAGER
  SITE_ENGINEER
  SITE_SUPERVISOR
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum VerificationType {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  PASSWORD_RESET
  INVITE
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReportType {
  DAILY_SITE_REPORT
  PROGRESS_REPORT
  INCIDENT_REPORT
  QUALITY_REPORT
}

enum NotificationEntityType {
  PROJECT
  TASK
  REPORT
  ISSUE
  MESSAGE
  USER
}

enum ChatType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Company {
  id        Int           @id @default(autoincrement())
  name      String
  email     String?       @unique
  phone     String?       @unique
  address   String?
  status    CompanyStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  users     User[]
  projects  Project[]
  materials MaterialUsed[]
  issues    Issue[]
  reports   Report[]

  @@index([name])
  @@map("companies")
}

model User {
  id           Int        @id @default(autoincrement())
  companyId    Int?
  role         UserRole
  firstName    String
  lastName     String
  email        String?    @unique
  phone        String?    @unique
  bio          String?
  passwordHash String
  isVerified   Boolean    @default(false)
  status       UserStatus @default(PENDING_VERIFICATION)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  company        Company?           @relation(fields: [companyId], references: [id])
  ownedProjects  Project[]          @relation("ProjectOwner")
  assignedTasks  Task[]             @relation("TaskAssignee")
  reports        Report[]
  notifications  Notification[]     @relation("NotificationRecipient")
  reportedIssues Issue[]            @relation("IssueReporter")
  assignedIssues Issue[]            @relation("IssueAssignee")
  issueAuditLogs IssueAuditLog[]
  sentMessages   Chat[]             @relation("ChatSender")
  sessions       Session[]
  verifications  VerificationCode[]

  @@index([companyId])
  @@index([role])
  @@index([status])
  @@map("users")
}

model Session {
  id               Int       @id @default(autoincrement())
  userId           Int
  refreshTokenHash String
  deviceInfo       String?
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model VerificationCode {
  id        Int              @id @default(autoincrement())
  userId    Int
  code      String
  type      VerificationType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
  @@map("verification_codes")
}

model Project {
  id            Int           @id @default(autoincrement())
  companyId     Int
  ownerUserId   Int
  projectName   String
  location      String
  startDate     DateTime
  endDate       DateTime?
  clientName    String
  projectBudget Decimal       @db.Decimal(15, 2)
  status        ProjectStatus @default(PLANNING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  company         Company          @relation(fields: [companyId], references: [id])
  owner           User             @relation("ProjectOwner", fields: [ownerUserId], references: [id])
  tasks           Task[]
  projectProgress ProjectProgress?
  reports         Report[]
  costSummary     CostSummary?
  issues          Issue[]
  chats           Chat[]

  @@index([companyId])
  @@index([ownerUserId])
  @@map("projects")
}

model ProjectProgress {
  id                   Int      @id @default(autoincrement())
  projectId            Int      @unique
  completionPercentage Decimal  @db.Decimal(5, 2)
  totalTasks           Int
  tasksCompleted       Int
  lastUpdated          DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_progress")
}

model Task {
  id              Int          @id @default(autoincrement())
  projectId       Int
  assigneeUserId  Int
  taskTitle       String
  taskDescription String?
  startDate       DateTime?
  dueDate         DateTime
  taskBudget      Decimal      @db.Decimal(15, 2)
  taskPriority    TaskPriority
  taskStatus      TaskStatus   @default(TODO)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee        User           @relation("TaskAssignee", fields: [assigneeUserId], references: [id])
  taskProgress    TaskProgress?
  materials       MaterialUsed[]
  blockedByIssues Issue[]        @relation("IssueBlockedTask")

  @@index([projectId])
  @@index([assigneeUserId])
  @@map("tasks")
}

model TaskProgress {
  id             Int        @id @default(autoincrement())
  taskId         Int        @unique
  daysRemaining  Int
  deadlineStatus String
  taskStatus     TaskStatus
  lastUpdated    DateTime   @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_progress")
}

model MaterialUsed {
  id               Int      @id @default(autoincrement())
  taskId           Int?
  materialName     String
  quantityUsed     Decimal  @db.Decimal(10, 2)
  unit             String
  usageDescription String?
  materialStatus   String
  task             Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  company          Company? @relation(fields: [companyId], references: [id])
  companyId        Int?

  @@index([taskId])
  @@map("materials_used")
}

model CostSummary {
  id             Int      @id @default(autoincrement())
  projectId      Int      @unique
  estimatedCost  Decimal  @db.Decimal(15, 2)
  actualTaskCost Decimal  @db.Decimal(15, 2)
  costVariance   Decimal  @db.Decimal(15, 2)
  lastUpdated    DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("cost_summaries")
}

model Report {
  id          Int        @id @default(autoincrement())
  userId      Int
  projectId   Int
  companyId   Int // Critical for multi-tenancy
  reportTitle String
  reportType  ReportType @default(DAILY_SITE_REPORT)
  reportDate  DateTime

  // Requirement fields: work, workers, materials, challenges
  workCompleted    String  @db.Text
  workersPresent   Int     @default(0)
  materialsUsed    String? @db.Text
  weatherCondition String?
  challenges       String? @db.Text

  progressPhotoUrl String?
  submittedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id])

  @@index([userId])
  @@index([projectId])
  @@index([companyId])
  @@map("reports")
}

model Notification {
  id                      Int                    @id @default(autoincrement())
  recipientUserId         Int
  notificationTitle       String
  notificationDescription String?
  notifiedDate            DateTime               @default(now())
  isRead                  Boolean                @default(false)
  relatedEntityType       NotificationEntityType
  relatedEntityId         Int

  recipient User @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, isRead])
  @@map("notifications")
}

model Issue {
  id            Int  @id @default(autoincrement())
  companyId     Int
  projectId     Int
  reporterId    Int?
  assigneeId    Int?
  blockedTaskId Int?

  title       String        @db.VarChar(200)
  description String
  location    String?       @db.VarChar(200)
  priority    IssuePriority @default(MEDIUM)
  status      IssueStatus   @default(OPEN)
  photoUrls   String[]      @default([])

  resolvedAt DateTime?
  closedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reporter    User?           @relation("IssueReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  assignee    User?           @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  blockedTask Task?           @relation("IssueBlockedTask", fields: [blockedTaskId], references: [id], onDelete: SetNull)
  auditLogs   IssueAuditLog[]

  @@index([companyId])
  @@index([projectId])
  @@index([reporterId])
  @@index([assigneeId])
  @@index([status])
  @@map("issues")
}

model IssueAuditLog {
  id        Int      @id @default(autoincrement())
  issueId   Int
  actorId   Int
  action    String   @db.VarChar(50)
  fromValue String?
  toValue   String?
  note      String?
  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actor User  @relation(fields: [actorId], references: [id])

  @@index([issueId])
  @@map("issue_audit_logs")
}

model Chat {
  id             Int      @id @default(autoincrement())
  senderUserId   Int
  projectId      Int
  messageContent String
  timestamp      DateTime @default(now())
  chatType       ChatType @default(TEXT)

  sender  User    @relation("ChatSender", fields: [senderUserId], references: [id])
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([senderUserId])
  @@index([projectId])
  @@map("chats")
}
